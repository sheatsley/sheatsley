# configuration variables
KEYID="D97737F91189673C"
ITERM=$HOME"/Library/Application Support/iTerm2/DynamicProfiles"
GITHUB=$HOME/repos

# move to home directory
echo "Moving to $HOME ..."
cd $HOME

# install brew if needed
BREW_PATH=$(which brew)
if [ -z "$BREW_PATH" ]; then
    /usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"
fi

# install homebrew-bundle, packages, casks and mas apps
brew bundle --verbose --file=.brewbundle

# add public gpg key to keyring
if ! gpg -k $KEYID; then
    echo "Downloading gpg public key $KEYID ..."
    gpg --card-edit --command-fd 0 <<< fetch
fi

# set gpg trust to ultimate
if ! gpg -k $KEYID | grep "ultimate"; then
    echo "Setting $KEYID trust to ultimate..."
    echo -e "5\n\y\n" | gpg --command-fd 0 --edit-key $KEYID trust
fi

# export env variables for ssh access with gpg
if [ -z "$SSH_AUTH_SOCK" ]; then 
    echo "Setting env variables for ssh access with gpg..."
    export GPG_TTY="$(tty)"
    export SSH_AUTH_SOCK=$(gpgconf --list-dirs agent-ssh-socket)
    gpgconf --launch gpg-agent
fi

# install the remaining applications through submodules
echo "Installing:\n-ohmyzsh\n-Vundle.vim\n-black\n-vim-fugitive\n-YouCompleteMe"
yadm submodule update --init
yadm submodule update --remote

# prep configuration files
echo "Configuring:\n-iTerm profiles\n-Mac OS"
if [ ! -f "$ITERM/sheatsley.json" ]; then
    mkdir -p $ITERM && ln -s $HOME/.sheatsley.json "$ITERM/sheatsley.json"
fi
sh $HOME/.macos

# download github repos
echo "Downloading GitHub repos..."
while IFS= read -r REPO
do
    if [ ! -d $GITHUB/$REPO ]; then
        git clone git@github.com:sheatsley/$REPO.git $GITHUB/$REPO
    fi
done < $HOME/.gitrepos

# install ycm semantic support
echo "Installing YCM semantic support..."
cd $HOME/.vim/bundle/YouCompleteMe && ./install.py --all && cd $HOME

# install all vim plugins
echo "Installing vim plugins..."
vim +PluginInstall +qall > /dev/null 2>&1

# convert yadm repo from https to ssh
YADM_REMOTE=$(yadm remote get-url origin | grep "git@github.com")
if [ -z "$YADM_REMOTE" ]; then
    echo "Changing remote url of yadm repo..."
    yadm remote set-url origin git@github.com:sheatsley/dotfiles.git
fi

# decrypt yadm files
echo "Decrypting files, please insert Yubikey..."
yadm git-crypt unlock

# logout (necessary for some settings)
echo "Bootstrap complete. Logging out..."
osascript -e 'tell app "System Events" to log out'

# configuration variables
BREW="https://raw.githubusercontent.com/Homebrew/install/master/install"
ITERM=$HOME"/Library/Application Support/iTerm2/DynamicProfiles"
GITHUB=$HOME/"repos"
GPGCONF="/usr/local/MacGPG2/bin"
KEYID="D97737F91189673C"
XCODE="/Library/Preferences/com.apple.dt.Xcode IDELastGMLicenseAgreedTo"

# move to home directory
echo "Moving to $HOME ..."
cd $HOME

# install brew if needed
BREW_PATH=$(which brew)
if [[ -z "$BREW_PATH" ]]
then
    echo "Installing brew..."
    /usr/bin/ruby -e "$(curl -fsSL $BREW)"
fi

# install homebrew-bundle, packages, casks and mas apps
echo "Updating brew packages..."
brew bundle --verbose --file=.brewbundle

# accept xcode license if necessary
if [[ $(which xcodebuild) && ! "$(defaults read ${XCODE})" ]]
then
    echo "Accepting XCode license.."
    sudo xcodebuild -license accept 
fi

# add public gpg key to keyring
if [[ -z $(gpg -k $KEYID) ]]
then
    echo "Downloading gpg public key $KEYID ..."
    gpg --card-edit --command-fd 0 <<< fetch
fi

# set gpg trust to ultimate
if [[ -z $(gpg -k $KEYID | grep "ultimate") ]]
then
    echo "Setting $KEYID trust to ultimate..."
    echo "5\ny\n" | gpg --command-fd 0 --edit-key $KEYID trust
fi

# convert yadm repo from https to ssh
YADM_REMOTE=$(yadm remote get-url origin | grep "git@github.com")
if [[ -z "$YADM_REMOTE" ]]
then
    echo "Changing remote url of yadm repo..."
    yadm remote set-url origin git@github.com:sheatsley/dotfiles.git
fi

# decrypt yadm files
if [[ $(grep -qsa "\0xGITCRYPT" $HOME/.gitrepos) ]]
    then
    echo "Decrypting files, please insert Yubikey..."
    if [[ ! $(yadm git-crypt unlock) ]]
    then
        exit 1
    fi
fi

# export env variables for ssh access with gpg
if [[ ! $(which gpgconf) ]]
then 
    echo "Setting env variables for ssh access with gpg..."
    eval `/usr/libexec/path_helper -s`
    export GPG_TTY="$(tty)"
    export SSH_AUTH_SOCK=$($GPGCONF/gpgconf --list-dirs agent-ssh-socket)
    $GPGCONF/gpgconf --launch gpg-agent
fi

# download github repos
echo "Updating GitHub repos..."
while IFS="/" read -r OWNER REPO
do
    if [[ ! -d $GITHUB/$REPO ]]
    then
        git clone git@github.com:$OWNER/$REPO.git $GITHUB/$REPO
    else
        git -C $GITHUB/$REPO pull
    fi
done < $HOME/.gitrepos

# updating the remaining applications through submodules
echo "Updating remaining applications:\n-ohmyzsh\n-Vundle.vim\n-black\n-vim-fugitive\n-YouCompleteMe"
yadm submodule update --init --recursive
yadm submodule update --remote

# updating all vim plugins
echo "Updating vim plugins..."
vim +PluginInstall +qall

# install ycm semantic support
if [[ ! -f $HOME/.vim/bundle/YouCompleteMe/third_party/ycmd/ycm_core.so ]]
then
    echo "Installing YCM semantic support..."
    cd $HOME/.vim/bundle/YouCompleteMe 
    ./install.py --all
    cd $HOME
fi

# prep configuration files and logout (necessary for some settings)
if [[ ! -f "$ITERM/sheatsley.json" ]]
then
    echo "Configuring:\n-iTerm profiles\n-Mac OS"
    mkdir -p "$ITERM" && ln -s $HOME/.sheatsley.json "${ITERM}/sheatsley.json"
    sh $HOME/.macos
    osascript -e 'tell app "System Events" to log out'
fi
echo "Bootstrap complete"

# Move to the user's home directory
echo "Moving to $HOME"
cd $HOME

# Get the OS
PLATFORM=$(uname -s)

# Change behaviour depending on the platform
if [ $PLATFORM = "Darwin" ]; then

    # Check if brew is installed, and install it if needed
    BREW_PATH=$(which brew)
    if [ -z "$BREW_PATH" ]; then
        echo "Installing Homebrew"
        /usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"
    fi

    # Install homebrew-bundle and all the brew packages, casks and mas apps
    brew bundle --verbose --file=.brewbundle

    # Install the pip packages from ~/.pip_requirements
    pip3 install -r .piprequirements

    # Convert the YADM repo from https to ssh
    YADM_REMOTE=$(yadm remote get-url origin | grep "git@github.com")
    if [ -z "$YADM_REMOTE" ]; then
        echo "Changing remote url of yadm repo"
        yadm remote set-url origin git@github.com:sheatsley/sheatsley.git
    fi

    # Install Oh My Zsh
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/robbyrussell/oh-my-zsh/master/tools/install.sh)"

    # Restore terminal settings
    cp ~/.terminalsettings ~/Library/Preferences/com.apple.Terminal.plist

    # Install Vundle
    git clone https://github.com/VundleVim/Vundle.vim.git ~/.vim/bundle/Vundle.vim

    # Install YouCompleteMe
    git clone https://github.com/Valloric/YouCompleteMe ~/.vim/bundle/YouCompleteMe
    cd ~/.vim/bundle/YouCompleteMe
    ./install.py --all
    vim +PluginInstall +qall

else 
    echo "This bootstrap file does not support Linux yet, aborting."
fi

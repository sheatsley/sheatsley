				<key>ActionBundlePath</key>
				<string>/System/Library/Automator/Run AppleScript.action</string>
				<key>ActionName</key>
				<string>Run AppleScript</string>
				<key>ActionParameters</key>
				<dict>
					<key>source</key>
					<string>tell application "System Events"		# get desktop width	tell application "Finder"		set bnds to bounds of window of desktop		set wide to item 3 of bnds	end tell		# determine how many monitors we have	if wide is equal to 1440 then		set dnum to "1"	else		set dnum to "2"	end if		# terminal peek magic	set activeApp to name of first application process whose frontmost is true	if "Terminal" is in activeApp then		set visible of process "Terminal" to false	else		tell application "Terminal"			activate			if dnum is equal to "1" then				set bounds of window 1 to {1710, -1, 2560, 2560}			else				set bounds of window 1 to {4270, -1, 5120, 2560}			end if		end tell	end ifend tell</string>
				</dict>
